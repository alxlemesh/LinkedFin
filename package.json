{
  "name": "my-project",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "engines": {
    "node": ">=24"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=10",
      "onFail": "error"
    }
  },
  "type": "module",
  "main": "app/main.ts",
  "scripts": {
    "start": "node --env-file=.env app/main.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --write .",
    "format": "prettier --write . && eslint . --fix"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-config-metarhia": "^9.1.9",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
